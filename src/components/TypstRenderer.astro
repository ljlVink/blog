---
import { extractTypstText } from "@/utils/typstTextExtractor";

type Props = {
  source: string;
};

const { source } = Astro.props;
const hiddenText = extractTypstText(source);
---

<div class="typst-svg-container not-prose">
  <slot />
  {hiddenText && (
    <div class="sr-only" aria-hidden="true">
      {hiddenText}
    </div>
  )}
</div>
